enum CarState { stop, drive, turn }

class Car {
  CarState state;

  Car(this.state);

  void stop() {
    state = CarState.stop;
  }

  void drive() {
    state = CarState.drive;
  }

  void turn() {
    state = CarState.turn;
  }

  String getState() {
    if (state == CarState.stop) {
      return "Стоп";
    } else if (state == CarState.drive) {
      return "Едет";
    } else {
      return "Поворачивает";
    }
  }
}

//ЗАДАНИЕ 8
abstract class Shape {
  double getArea();
}

class Rectangle extends Shape {
  double width, height;

  Rectangle(this.width, this.height);

  @override
  double getArea() {
    return width * height;
  }
}

class Triangle extends Shape {
  double base, height;

  Triangle(this.base, this.height);

  @override
  double getArea() {
    return 0.5 * base * height;
  }
}

class Circle extends Shape {
  double radius;

  Circle(this.radius);

  @override
  double getArea() {
    return 3.14 * radius * radius;
  }
}

//ЗАДАНИЕ 9
class NumberConverter {
  String decimalToHex(int num) {
    return num.toRadixString(16).toUpperCase();
  }

  String decimalToOct(int num) {
    return num.toRadixString(8);
  }

  int hexToDecimal(String hex) {
    return int.parse(hex, radix: 16);
  }

  int octToDecimal(String oct) {
    return int.parse(oct, radix: 8);
  }
}

//ЗАДАНИЕ 10
abstract class Shape_2 {
  double getArea();
}

class Rectangle_2 extends Shape_2 {
  double width, height;

  Rectangle_2(this.width, this.height);

  @override
  double getArea() {
    return width * height;
  }
}

class Circle_2 extends Shape_2 {
  double radius;

  Circle_2(this.radius);

  @override
  double getArea() {
    return 3.14 * radius * radius;
  }
}

class ShapeList {
  List<Shape_2> shapes = [];

  void add(Shape_2 s) {
    shapes.add(s);
  }

  Shape_2 getMaxArea() {
    Shape_2 max = shapes[0];
    for (int i = 1; i < shapes.length; i++) {
      if (shapes[i].getArea() > max.getArea()) {
        max = shapes[i];
      }
    }
    return max;
  }

  double getMaxAreaValue() {
    return getMaxArea().getArea();
  }
}

