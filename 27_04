abstract class Grif {
  int leftSide;
  int rightSide;
  int maxWeight;

  Grif(this.leftSide, this.rightSide, this.maxWeight);

  String putOnLeftSide(int weight);
  String putOnRightSide(int weight);
}

class Blin extends Grif {
  int weight;
  String color;
  Blin(this.weight, this.color) : super(0, 0, 120);

  @override
  String putOnLeftSide(int weight) {
    leftSide += weight;
    if (leftSide + rightSide >= maxWeight) {
      print("Вы не можете навесить в сумме больше $maxWeight kg");
      leftSide -= weight;
    }
    return "Вы повесили на левую сторону $weight кг";
  }

  @override
  String putOnRightSide(int weight) {
    rightSide += weight;
    if (rightSide + leftSide >= maxWeight) {
      print("Вы не можете навесить в сумме больше $maxWeight kg");
      rightSide -= weight;
    }
    return "Вы повесили на правую сторону $weight кг";
  }
}

//ЗАДАНИЕ 4
class Converter {
  double value;
  double result;

  Converter(this.value, this.result);

  String convert() {
    print(
      "Введите название валюты, из которой будем переводить: rub, eur, usd",
    );
    String? currency = stdin.readLineSync();

    switch (currency) {
      case "rub":
        print("Сколько денег?");
        String? input = stdin.readLineSync();
        value = double.parse(input!);
        double rubUsd = value / 75;
        double rubEuro = value / 88;
        result = rubUsd;
        return "В долларах - $rubUsd, В евро - $rubEuro";

      case "eur":
        print("Сколько денег?");
        String? input = stdin.readLineSync();
        value = double.parse(input!);
        double eurRub = value * 88;
        double eurUsd = value * 1.17;
        result = eurUsd;
        return "В рублях - $eurRub, в долларах - $eurUsd";

      case "usd":
        print("Сколько денег?");
        String? input = stdin.readLineSync();
        value = double.parse(input!);
        double usdRub = value * 75;
        double usdEur = value / 1.17;
        result = usdRub;
        return "В рублях - $usdRub, в Евро - $usdEur";

      default:
        print("Вы ввели: '$currency'");
        return "Ошибка: неверная валюта. Доступны: rub, eur, usd";
    }
  }
}

//ЗАДАНИЕ 6
class Number {
  double value;
  Number(this.value);

  Number plus(Number other) {
    return Number(value + other.value);
  }

  Number minus(Number other) {
    return Number(value - other.value);
  }

  Number times(Number other) {
    return Number(value * other.value);
  }

  Number dividedBy(Number other) {
    return Number(value / other.value);
  }

  bool equals(Number other) {
    return value == other.value;
  }

  void show() {
    print(value);
  }
}

