    return "Вилка";
  }
}

class Spoon extends Tableware {
  @override
  String getName() {
    return "Ложка";
  }
}

class Knife extends Tableware {
  @override
  String getName() {
    return "Нож";
  }
}

class Table {
  List<Tableware> items = [];

  void put(Tableware item) {
    items.add(item);
    print("${item.getName()} поставлен на стол");
  }

  void remove(Tableware item) {
    items.remove(item);
    print("${item.getName()} убран со стола");
  }

  void showItems() {
    print("На столе:");
    for (var item in items) {
      print("- ${item.getName()}");
    }
  }
}

