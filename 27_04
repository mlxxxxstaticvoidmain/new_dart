//ЗАДАНИЕК 2
abstract class Wardrobe {
  List<String> firstShelf;
  List<String> secondShelf;
  List<String> thirdShelf;

  Wardrobe(this.firstShelf, this.secondShelf, this.thirdShelf);

  String putOnFirstShelf(String item);
  String takeFromFirstShelf(String item);

  String putOnSecondShelf(String item);
  String takeFromSecondShelf(String item);

  String putOnThirdShelf(String item);
  String takeFromThirdShelf(String item);
}

class Polzovatel implements Wardrobe {
  int age;
  String name;

  @override
  List<String> firstShelf;

  @override
  List<String> secondShelf;

  @override
  List<String> thirdShelf;

  Polzovatel(
    this.age,
    this.name,
    this.firstShelf,
    this.secondShelf,
    this.thirdShelf,
  );

  @override
  String putOnFirstShelf(String item) {
    firstShelf.add(item);
    return "Вы положили предмет $item на первую полку";
  }

  @override
  String takeFromFirstShelf(String item) {
    firstShelf.remove(item);
    return "Вы взяли предмет $item с первой полки";
  }

  @override
  String putOnSecondShelf(String item) {
    secondShelf.add(item);
    return "Вы положили предмет $item на вторую полку";
  }

  @override
  String takeFromSecondShelf(String item) {
    secondShelf.remove(item);
    return "Вы взяли предмет $item со второй полки";
  }

  @override
  String putOnThirdShelf(String item) {
    thirdShelf.add(item);
    return "Вы положили предмет $item на третью полку";
  }

  @override
  String takeFromThirdShelf(String item) {
    thirdShelf.remove(item);
    return "Вы взяли предмет $item с третьей полки";
  }
}

