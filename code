import 'dart:convert';
import 'dart:io';
import 'dart:math';
import 'package:characters/characters.dart';

enum Mood {
  joy('\u{1F600}', 'радостное', 10),
  excitement('\u{1F60E}', 'взволнованный', 9),
  calm('\u{1F9D8}', 'спокойное', 5),
  energetic('\u{26A1}', 'энергичное', 8),
  sadness('\u{1F622}', 'грустное', 3);

  final String emoji;
  final String description;
  final int energy;

  const Mood(this.emoji, this.description, this.energy);
}

void main() {
  print("Введите ваше имя: ");
  String name = stdin.readLineSync(encoding: utf8)!;

  print("Генерируем случайное настроение...");
  sleep(Duration(seconds: 2));

  var moods = Mood.values;
  var random = Random();
  var mood = moods[random.nextInt(moods.length)];

  print(
    'Привет, $name! Твое настроение: ${mood.emoji} ${mood.description} (энергия: ${mood.energy}/10)',
  );

  int codePoint = mood.emoji.runes.first;
  print("Юникод вашего эмодзи: U+${codePoint.toRadixString(16).toUpperCase()}");

  print("\nХотите просмотреть сложные эмодзи? (да/нет): ");
  String decision = stdin.readLineSync(encoding: utf8)!;

  if (decision.toLowerCase().trim() == "да") {
    print("Введите комбинацию эмодзи: ");
    String input = stdin.readLineSync(encoding: utf8)!;

    print('\nАнализ строки "$input":');
    print('- 16-битных единиц: ${input.codeUnits.length}');
    print('- Кодовых точек: ${input.runes.length}');
    print('- Реальных символов: ${input.characters.length}');

    print('\nПодробный вывод юникода:');
    int i = 1;
    for (var rune in input.runes) {
      String symbol = String.fromCharCode(rune);
      print('Символ $i: $symbol → U+${rune.toRadixString(16).toUpperCase()}');
      i++;
    }
  }

  print('\nСпасибо, приходите снова!');
}
